# ─── Core ────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=Spur
LOG_LEVEL=info

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgres://spur:changeme@postgres:5432/spur?sslmode=disable
POSTGRES_DB=spur
POSTGRES_USER=spur
POSTGRES_PASSWORD=changeme

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── UI ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_THEME=spur

# ─── WEBSOCKET ───────────────────────────────────────────────────
# WebSocket endpoint path
WS_PATH=/ws
# Keepalive ping interval
WS_PING_INTERVAL=30s
# Max WebSocket message size (bytes)
WS_MAX_MSG_SIZE=65536

# ─── TEMPORAL ───────────────────────────────────────────────────
# Temporal server address
TEMPORAL_HOST=
# Temporal namespace
TEMPORAL_NAMESPACE=default
# Run worker in-process (false = separate worker binary)
TEMPORAL_WORKER=true

# ─── QUEUE ───────────────────────────────────────────────────
# Redis Streams key prefix
QUEUE_PREFIX=spur
# Max messages to retain per stream
QUEUE_MAX_LEN=10000

# ─── Observability ──────────────────────────────────────────
GRAFANA_PASSWORD=admin
